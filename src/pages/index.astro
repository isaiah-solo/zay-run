---
import Counter from '../components/Counter.tsx';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Isaiah Solomon">
	<main class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-center justify-center gap-6 px-6">
		<h1 class="text-4xl font-bold tracking-tight">zay.run</h1>
		<p class="text-zinc-600 dark:text-zinc-400">
			Astro 7 + React 19 + TypeScript + Tailwind 4 — scaffolding is live.
		</p>
		<Counter client:load />
	</main>
</BaseLayout>
