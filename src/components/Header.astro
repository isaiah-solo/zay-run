---
const links = [
	{ href: '/about', label: 'About' },
	{ href: '/projects', label: 'Projects' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="mx-auto flex w-full max-w-2xl items-center justify-between px-6 py-6">
	<a href="/" class="font-semibold tracking-tight hover:text-zinc-600 dark:hover:text-zinc-300">
		zay
	</a>
	<nav class="flex items-center gap-6 text-sm">
		{
			links.map(({ href, label }) => (
				<a
					href={href}
					class:list={[
						'transition-colors hover:text-zinc-900 dark:hover:text-zinc-100',
						currentPath === href
							? 'text-zinc-900 dark:text-zinc-100'
							: 'text-zinc-500 dark:text-zinc-400',
					]}
				>
					{label}
				</a>
			))
		}
	</nav>
</header>
